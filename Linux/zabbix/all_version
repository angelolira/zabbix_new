#!/bin/bash
set -e
clear

# ========================
# Variáveis
# ========================

CONF_AGENT1_URL="https://raw.githubusercontent.com/angelolira/zabbix_new/refs/heads/main/Linux/zabbix/zabbix_agentd.conf"
CONF_AGENT2_URL="https://raw.githubusercontent.com/angelolira/zabbix_new/refs/heads/main/Linux/zabbix/zabbix_agent2.conf"

CONF_AGENT1_MARINGA_URL="https://raw.githubusercontent.com/angelolira/zabbix_new/refs/heads/main/Linux/zabbix/zabbix_agentMGA.conf"
CONF_AGENT2_MARINGA_URL="https://raw.githubusercontent.com/angelolira/zabbix_new/refs/heads/main/Linux/zabbix/zabbix_agent2MGA.conf"

CONF_AGENT2_UNA_URL="https://raw.githubusercontent.com/angelolira/zabbix_new/refs/heads/main/Linux/zabbix/zabbix_agent2UNA.conf"

CONF_AGENT1="zabbix_agentd.conf"
CONF_AGENT2="zabbix_agent2.conf"

ZABBIX_DIR="/etc/zabbix"
SUDOERS_FILE="/etc/sudoers.d/zabbix"

# ========================
# Funções utilitárias
# ========================

require_root() {
    [[ "$(id -u)" == "0" ]] || { echo "❌ Execute como root"; exit 1; }
}

detect_os() {
    source /etc/os-release
    OS_ID="$ID"
    OS_VERSION="$VERSION_ID"
}

pkg_install() {
    case "$OS_VERSION" in
        6*|7*) yum install -y "$@";;
        8*|9*) dnf install -y "$@";;
    esac
}

pkg_remove() {
    case "$OS_VERSION" in
        6*|7*) yum remove -y "$@";;
        8*|9*) dnf remove -y "$@";;
    esac
}

service_enable() {
    [[ "$OS_VERSION" == 6* ]] && chkconfig "$1" on || systemctl enable "$1"
}

service_restart() {
    [[ "$OS_VERSION" == 6* ]] && service "$1" restart || systemctl restart "$1"
}

# ========================
# Corrigir usuário Zabbix
# ========================

fix_zabbix_user() {

    echo "🔎 Verificando usuário zabbix..."

    if id zabbix &>/dev/null; then

        USER_HOME=$(getent passwd zabbix | cut -d: -f6)

        if [[ "$USER_HOME" == *"@"* ]]; then
            echo "⚠ Usuário zabbix vindo do AD detectado. Criando usuário local..."

            userdel zabbix 2>/dev/null || true
            useradd -r -s /sbin/nologin zabbix
        fi

    else
        echo "👤 Criando usuário zabbix local..."
        useradd -r -s /sbin/nologin zabbix
    fi
}

# ========================
# Sudoers
# ========================

add_zabbix_sudoers() {

    fix_zabbix_user

    echo "✍ Criando sudoers..."

cat > "$SUDOERS_FILE" <<EOF
zabbix ALL=(root) NOPASSWD: /usr/local/bin/zbx_admin_sudo
zabbix ALL=(root) NOPASSWD: /usr/bin/systemctl restart *
zabbix ALL=(root) NOPASSWD: /usr/bin/find *
zabbix ALL=(root) NOPASSWD: /usr/bin/grep
zabbix ALL=(root) NOPASSWD: /usr/bin/tail
zabbix ALL=(root) NOPASSWD: /usr/bin/df
zabbix ALL=(root) NOPASSWD: /usr/bin/docker *
EOF

    chmod 440 "$SUDOERS_FILE"

    visudo -cf "$SUDOERS_FILE" || {
        echo "❌ Erro no sudoers"
        exit 1
    }

    echo "✔ Sudoers validado"
}

# ========================
# UserParameters
# ========================

add_userparameters() {

    AGENT_TYPE="$1"

    if [[ "$AGENT_TYPE" == "agent2" ]]; then
        CONF_DIR="$ZABBIX_DIR/zabbix_agent2.d"
    else
        CONF_DIR="$ZABBIX_DIR/zabbix_agentd.d"
    fi

    local UP_FILE="$CONF_DIR/custom_linux.conf"

    echo "➕ Criando UserParameters..."

    mkdir -p "$CONF_DIR"

cat > "$UP_FILE" <<EOF
UserParameter=custom.df,sudo /usr/bin/df -h
UserParameter=custom.find,sudo /usr/bin/find / -maxdepth 1
UserParameter=custom.tail,sudo /usr/bin/tail -n 10 /var/log/messages
UserParameter=custom.grep,sudo /usr/bin/grep ERROR /var/log/messages
UserParameter=apache.restart,sudo /usr/bin/systemctl restart httpd
EOF

}

# ========================
# Instalar Agent 1
# ========================

install_agent1() {

    echo "➡ Instalando Zabbix Agent"

    case "$OS_VERSION" in
        6*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/6/x86_64/zabbix-release-6.0-4.el6.noarch.rpm;;
        7*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/7/x86_64/zabbix-release-6.0-4.el7.noarch.rpm;;
        8*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/8/x86_64/zabbix-release-6.0-4.el8.noarch.rpm;;
        9*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/9/x86_64/zabbix-release-6.0-4.el9.noarch.rpm;;
    esac

    pkg_install zabbix-agent

    service_enable zabbix-agent

    if [[ "$SITE" == "MARINGA" ]]; then
        CONF_URL="$CONF_AGENT1_MARINGA_URL"
    else
        CONF_URL="$CONF_AGENT1_URL"
    fi

    curl -fsSLo "$ZABBIX_DIR/$CONF_AGENT1" "$CONF_URL"

    add_userparameters "agent1"
    add_zabbix_sudoers

    service_restart zabbix-agent

    echo "✅ Zabbix Agent instalado"
}

# ========================
# Instalar Agent 2
# ========================

install_agent2() {

    echo "➡ Instalando Zabbix Agent 2"

    case "$OS_VERSION" in
        6*) echo "❌ Agent2 não suporta RHEL6"; exit 1;;
        7*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/7/x86_64/zabbix-release-6.0-4.el7.noarch.rpm;;
        8*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/8/x86_64/zabbix-release-6.0-4.el8.noarch.rpm;;
        9*) rpm -Uvh https://repo.zabbix.com/zabbix/6.0/rhel/9/x86_64/zabbix-release-6.0-4.el9.noarch.rpm;;
    esac

    pkg_install zabbix-agent2

    service_enable zabbix-agent2

    case "$SITE" in
        MARINGA) CONF_URL="$CONF_AGENT2_MARINGA_URL" ;;
        TIMBO) CONF_URL="$CONF_AGENT2_URL" ;;
        UNIASSELVI) CONF_URL="$CONF_AGENT2_UNA_URL" ;;
        *) echo "❌ SITE inválido"; exit 1 ;;
    esac

    [[ -z "$CONF_URL" ]] && { echo "❌ URL não definida"; exit 1; }

    echo "Baixando configuração: $CONF_URL"

    curl -fsSLo "$ZABBIX_DIR/$CONF_AGENT2" "$CONF_URL"

    add_userparameters "agent2"
    add_zabbix_sudoers

    service_restart zabbix-agent2

    echo "✅ Zabbix Agent2 instalado"
}

# ========================
# Remover Zabbix
# ========================

zabbix_remove() {

    echo "🗑 Removendo Zabbix..."

    pkg_remove zabbix-agent zabbix-agent2 zabbix-release || true

    rm -rf "$ZABBIX_DIR"
    rm -f "$SUDOERS_FILE"

    echo "✅ Zabbix removido"
}

# ========================
# Menu Site
# ========================

choose_site() {

    local AGENT_TYPE=$1

    echo
    echo "Selecione a localidade:"
    echo "1 - MARINGÁ"
    echo "2 - TIMBÓ"

    if [[ "$AGENT_TYPE" == "agent2" ]]; then
        echo "3 - UNIASSELVI"
    fi

    read -rp "Escolha: " site_opt

    case "$site_opt" in
        1) SITE="MARINGA" ;;
        2) SITE="TIMBO" ;;
        3)
            if [[ "$AGENT_TYPE" == "agent2" ]]; then
                SITE="UNIASSELVI"
            else
                echo "Opção inválida"
                sleep 2
                choose_site "$AGENT_TYPE"
            fi
            ;;
        *)
            echo "Opção inválida"
            sleep 2
            choose_site "$AGENT_TYPE"
            ;;
    esac
}

# ========================
# Menu instalação
# ========================

zabbix_install_menu() {

    echo
    echo "Qual versão deseja instalar?"
    echo "1 - Zabbix Agent"
    echo "2 - Zabbix Agent 2"

    read -rp "Escolha: " agent_opt

    case "$agent_opt" in
    1)
        choose_site "agent1"
        install_agent1
        ;;
    2)
        choose_site "agent2"
        install_agent2
        ;;
    *)
        echo "Opção inválida"
        sleep 2
        zabbix_install_menu
        ;;
esac

}

# ========================
# Menu principal
# ========================

main_menu() {

    require_root
    detect_os

    clear

    echo "==============================="
    echo "   INSTALADOR ZABBIX"
    echo "==============================="
    echo "Sistema: $OS_ID $OS_VERSION"
    echo
    echo "1 - Instalar Zabbix"
    echo "2 - Remover Zabbix"
    echo "0 - Sair"

    read -rp "Escolha: " opt

    case "$opt" in
        1) zabbix_install_menu;;
        2) zabbix_remove;;
        0) exit 0;;
        *) echo "Opção inválida"; sleep 2; main_menu;;
    esac
}

main_menu
